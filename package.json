    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-chrome": "^0.8.0",
    "jest-environment-jsdom": "^30.2.0",
    "jiti": "^2.6.1",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.8.3",
